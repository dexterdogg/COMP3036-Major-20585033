  "type": "module",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "test": "NODE_ENV=test node --test --test-concurrency=1 tests/integration/**/*.test.js",
    "test:e2e": "NODE_ENV=test playwright test",
