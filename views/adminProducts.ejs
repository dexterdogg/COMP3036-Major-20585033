<!DOCTYPE html>
<html lang="en">
<head>
  <title><%= title %></title>
  <link rel="stylesheet" href="/stylesheets/style.css">
  <meta name="viewport" content="width=device-width, initial-scale=1">
</head>
<body>
  <%- include('navbar') %>

  <main class="page">
    <header class="page-header">
      <h1>Admin Dashboard</h1>
      <p>Manage products and view purchase records.</p>
    </header>

    <% if (error) { %>
      <p class="alert"><%= error %></p>
    <% } %>

    <section class="checkout-layout">
      <article class="card">
        <h2><%= editingProduct ? 'Edit Product' : 'Create Product' %></h2>

        <form method="POST" action="<%= editingProduct ? `/admin/products/${editingProduct.id}/update` : '/admin/products' %>">
          <label>
            Name
            <input name="name" value="<%= editingProduct?.name || '' %>" required>
          </label>

          <label>
            Slug
            <input name="slug" value="<%= editingProduct?.slug || '' %>" placeholder="auto-generated if blank">
          </label>

          <label>
            Category
            <select name="categoryId" required>
              <% categories.forEach((category) => { %>
                <option
                  value="<%= category.id %>"
                  <%= editingProduct?.category_id === category.id ? 'selected' : '' %>
                >
                  <%= category.name %>
                </option>
              <% }) %>
            </select>
          </label>

          <label>
            Description
            <textarea name="description" rows="4"><%= editingProduct?.description || '' %></textarea>
          </label>

          <label>
            Price
            <input
              name="price"
              type="number"
              step="0.01"
              min="0"
              value="<%= editingProduct ? (editingProduct.price_cents / 100).toFixed(2) : '' %>"
              required
            >
          </label>

          <label>
            Image URL
            <input name="imageUrl" value="<%= editingProduct?.image_url || '' %>">
          </label>

          <label>
            Stock quantity
            <input
              name="stockQuantity"
              type="number"
              min="0"
              value="<%= editingProduct?.stock_quantity ?? 0 %>"
              required
            >
          </label>

          <label class="checkbox">
            <input
              type="checkbox"
              name="isActive"
              <%= editingProduct?.is_active === false ? '' : 'checked' %>
            >
            Active
          </label>

          <button class="button" type="submit">
            <%= editingProduct ? 'Save Product' : 'Create Product' %>
          </button>

          <% if (editingProduct) { %>
            <a class="button secondary" href="/admin/products">Cancel</a>
          <% } %>
        </form>
      </article>

      <article class="card">
        <h2>Purchase Records</h2>

        <% if (purchases.length === 0) { %>
          <p>No purchases yet.</p>
        <% } else { %>
          <table>
            <thead>
              <tr>
                <th>Order</th>
                <th>User</th>
                <th>Total</th>
                <th>Status</th>
              </tr>
            </thead>

            <tbody>
              <% purchases.forEach((purchase) => { %>
                <tr>
                  <td>#<%= purchase.id %></td>
                  <td><%= purchase.email %></td>
                  <td><%= formatMoney(purchase.total_cents) %></td>
                  <td><%= purchase.status %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </article>
    </section>

    <section class="card">
      <h2>Products</h2>

      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Category</th>
            <th>Price</th>
            <th>Stock</th>
            <th>Active</th>
            <th>Actions</th>
          </tr>
        </thead>

        <tbody>
          <% products.forEach((product) => { %>
            <tr>
              <td><%= product.name %></td>
              <td><%= product.category_name || '—' %></td>
              <td><%= formatMoney(product.price_cents) %></td>
              <td><%= product.stock_quantity %></td>
              <td><%= product.is_active ? 'Yes' : 'No' %></td>
              <td>
                <a href="/admin/products/<%= product.id %>/edit">Edit</a>

                <form method="POST" action="/admin/products/<%= product.id %>/delete" class="inline-form">
                  <button class="danger" type="submit">Deactivate</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  </main>
</body>
</html>