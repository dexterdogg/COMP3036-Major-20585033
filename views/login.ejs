<%- include('navbar') %>

<main class="page auth-page">
  <section class="auth-shell">
    
    <section class="auth-panel auth-form-card" aria-labelledby="login-heading">
      <p class="eyebrow">Account Access</p>

      <h2 id="login-heading">Log in</h2>

      <p class="auth-muted">
        Use your seeded student or administrator account to access the store.
      </p>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert" role="alert">
          <%= error %>

        </div>
      <% } %>

      <form class="auth-form" action="/login" method="post" novalidate>
        <label for="email">
          
          Email address
          <input
            id="email"
            name="email"
            type="email"
            autocomplete="email"
            placeholder="student1@example.edu"
            value="<%= typeof values !== 'undefined' && values.email ? values.email : '' %>"
            required
          >
        </label>

        <label for="password">
          Password
          <input
            id="password"
            name="password"
            type="password"
            autocomplete="current-password"
            placeholder="Enter your password"
            required
          >
        </label>

        <button class="auth-submit" type="submit">
          Log in
        </button>
      </form>

      <div class="auth-footer">
        <span>New to the store?</span>
        <a href="/register">Create an account</a>
      </div>
    </section>
  </section>
</main>