<!DOCTYPE html>
<html>

<head>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
        body {
            margin: 0;
            font-family: Arial, Helvetica, sans-serif;
        }

        .sidebar-container {
            position: fixed;
            top: 0;
            left: -200px;
            width: 265px;
            height: 100vh;
            display: flex;
            transition: left 0.3s ease;
            z-index: 1000;
        }

        .sidebar-container.open {
            left: 0;
        }

        .hamburger {
            width: 45px;
            padding-top: 10px;
            margin-left: 5px;
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
            align-items: center;
            cursor: pointer;
        }

        .bar1,
        .bar2,
        .bar3 {
            width: 35px;
            height: 5px;
            background-color: #111;
            margin: 4px 0;
            transition: 0.2s;
        }

        .change .bar1 {
            transform: translate(0, 13px) rotate(-45deg);
        }

        .change .bar2 {
            opacity: 0;
        }

        .change .bar3 {
            transform: translate(0, -13px) rotate(45deg);
        }

        .sidebar {
            width: 200px;
            height: 100%;
            background-color: #333;
            border-right: 6px solid #b6b6b6;
        }

        .sidebar a {
            display: block;
            color: #f2f2f2;
            text-align: center;
            padding: 14px 16px;
            text-decoration: none;
            font-size: 17px;
        }

        .sidebar a:hover {
            background-color: #ddd;
            color: black;
        }

        .sidebar a.active {
            background-color: #c71b04;
            color: white;
        }
    </style>


</head>

<body>
    <div id="sidebar-container" class="sidebar-container">
        <div class="sidebar">
            <a href="/">Home</a>
            <a href="/search">Search</a>
            <a href="/moodTracker">Mood Tracker</a>
            <a href="/taskBoard">Task Board</a>
            <a href="/profile">Profile</a>
            <a href="/login">Login Page</a>

            <% if (isAuthed) { %>
                <a href="/logout">Logout</a>
                <% } %>


                
        </div>

        <div class="hamburger" onclick="sideMenu(this)">
            <div class="bar1"></div>
            <div class="bar2"></div>
            <div class="bar3"></div>
        </div>
    </div>


    <script>
        function sideMenu(x) {
            x.classList.toggle("change")
            const sidebarContainer = document.getElementById("sidebar-container");
            const content = document.getElementById("mainContent");

            sidebarContainer.classList.toggle("open");

            if (sidebarContainer.classList.contains("open")) {
                content.style.marginLeft = "200px";
            } else {
                content.style.marginLeft = "0px";
            }
        }

    </script>

</body>

</html>