<!DOCTYPE html>
<html lang="en">
<head>
  <title><%= title %></title>
  <link rel="stylesheet" href="/stylesheets/style.css">
  <meta name="viewport" content="width=device-width, initial-scale=1">
</head>
<body>
  <%- include('navbar') %>

  <main class="page">
    <header class="page-header">
      <h1>Order #<%= purchase.id %></h1>
      <p><%= new Date(purchase.created_at).toLocaleString('en-AU') %></p>
    </header>

    <section class="card">
      <table>
        <thead>
          <tr>
            <th>Product</th>
            <th>Unit Price</th>
            <th>Quantity</th>
            <th>Total</th>
          </tr>
        </thead>

        <tbody>
          <% items.forEach((item) => { %>
            <tr>
              <td><%= item.product_name %></td>
              <td><%= formatMoney(item.unit_price_cents) %></td>
              <td><%= item.quantity %></td>
              <td><%= formatMoney(item.line_total_cents) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>

      <p class="price">Order total: <%= formatMoney(purchase.total_cents) %></p>
    </section>
  </main>
</body>
</html>