<!DOCTYPE html>
<html lang="en">
<head>
  <title><%= title %></title>
  <link rel="stylesheet" href="/stylesheets/style.css">
  <meta name="viewport" content="width=device-width, initial-scale=1">
</head>
<body>
  <%- include('navbar') %>

  <main class="page">
    <header class="page-header">
      <h1>My Orders</h1>
      <p>Review your past purchases.</p>
    </header>

    <% if (purchases.length === 0) { %>
      <section class="card">
        <p>You do not have any purchases yet.</p>
        <a class="button" href="/products">Browse Products</a>
      </section>
    <% } else { %>
      <section class="card">
        <table>
          <thead>
            <tr>
              <th>Order</th>
              <th>Date</th>
              <th>Items</th>
              <th>Total</th>
              <th>Status</th>
            </tr>
          </thead>

          <tbody>
            <% purchases.forEach((purchase) => { %>
              <tr>
                <td><a href="/orders/<%= purchase.id %>">#<%= purchase.id %></a></td>
                <td><%= new Date(purchase.created_at).toLocaleDateString('en-AU') %></td>
                <td><%= purchase.item_count %></td>
                <td><%= formatMoney(purchase.total_cents) %></td>
                <td><%= purchase.status %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </section>
    <% } %>
  </main>
</body>
</html>