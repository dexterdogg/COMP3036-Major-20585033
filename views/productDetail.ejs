<!DOCTYPE html>
<html lang="en">
<head>
  <title><%= title %></title>
  <link rel="stylesheet" href="/stylesheets/style.css">
  <meta name="viewport" content="width=device-width, initial-scale=1">
</head>
<body>
  <%- include('navbar') %>

  <main class="page product-detail">
    <img src="<%= product.image_url %>" alt="<%= product.name %>">

    <section>
      <p class="eyebrow"><%= product.category_name || 'General' %></p>
      <h1><%= product.name %></h1>
      <p><%= product.description %></p>
      <p class="price"><%= formatMoney(product.price_cents) %></p>
      <p><%= product.stock_quantity %> available</p>

      <% if (isAuthed) { %>
        <form method="POST" action="/cart/items">
          <input type="hidden" name="productId" value="<%= product.id %>">

          <label>
            Quantity
            <input type="number" name="quantity" min="1" max="<%= product.stock_quantity %>" value="1">
          </label>

          <button class="button" type="submit">Add to Cart</button>
        </form>
      <% } else { %>
        <a class="button" href="/login">Login to Buy</a>
      <% } %>
    </section>
  </main>
</body>
</html>