<!DOCTYPE html>
<html lang="en">
<head>
  <title><%= title || 'My Account' %></title>
  <link rel="stylesheet" href="/stylesheets/style.css">
  <meta name="viewport" content="width=device-width, initial-scale=1">
</head>
<body>
  <%- include('navbar') %>

  <main class="page">
    <header class="page-header">
      <h1>My Account</h1>
      <p>Your account details and recent purchase history.</p>
    </header>

    <section class="card">
      <h2><%= (me?.firstName || '') + (me?.lastName ? ' ' + me.lastName : '') || 'User' %></h2>
      <p>Email: <%= me?.email || '—' %></p>
      <p>Role: <%= me?.role || '—' %></p>
    </section>

    <section class="card">
      <h2>Recent Purchases</h2>

      <% if (!purchases || purchases.length === 0) { %>
        <p>No purchases yet.</p>
      <% } else { %>
        <ul>
          <% purchases.slice(0, 5).forEach((purchase) => { %>
            <li>
              <a href="/orders/<%= purchase.id %>">
                Order #<%= purchase.id %>
              </a>
              — $<%= (Number(purchase.total_cents) / 100).toFixed(2) %>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </section>
  </main>
</body>
</html>