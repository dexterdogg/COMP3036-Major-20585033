<%- include('navbar') %>

<main class="page auth-page">
  <section class="auth-shell">
    

    <section class="auth-panel auth-form-card" aria-labelledby="register-heading">
      <p class="eyebrow">New Account</p>

      <h2 id="register-heading">Register</h2>

      <p class="auth-muted">
        Use your university email address. All public registrations are created as student
        accounts.
      </p>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert" role="alert">
          <%= error %>
        </div>
      <% } %>

      <form class="auth-form" action="/register" method="post" novalidate>
        <div class="auth-two-column">
          <label for="firstName">
            First name
            <input
              id="firstName"
              name="firstName"
              type="text"
              autocomplete="given-name"
              placeholder="Alex"
              value="<%= typeof values !== 'undefined' && values.firstName ? values.firstName : '' %>"
              required
            >
          </label>

          <label for="lastName">
            Last name
            <input
              id="lastName"
              name="lastName"
              type="text"
              autocomplete="family-name"
              placeholder="Smith"
              value="<%= typeof values !== 'undefined' && values.lastName ? values.lastName : '' %>"
              required
            >
          </label>
        </div>

        <label for="email">
          Email address
          <input
            id="email"
            name="email"
            type="email"
            autocomplete="email"
            placeholder="student1@example.edu"
            value="<%= typeof values !== 'undefined' && values.email ? values.email : '' %>"
            required
          >
        </label>

        <label for="password">
          Password
          <input
            id="password"
            name="password"
            type="password"
            autocomplete="new-password"
            placeholder="Minimum 8 characters"
            minlength="8"
            required
          >
        </label>

        <button class="auth-submit" type="submit">
          Create account
        </button>
      </form>

      <div class="auth-footer">
        <span>Already have an account?</span>
        <a href="/login">Back to login</a>
      </div>
    </section>
  </section>
</main>